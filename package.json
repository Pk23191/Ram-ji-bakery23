{
  "name": "ramji-bakery",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/predev-clean.js",
    "dev": "node scripts/dev.js",
    "client:dev": "cd client && npm run dev",
    "server:dev": "cd server && npm run dev",
    "client:build": "npm --prefix client run build",
    "server:start": "node server/server.js",
    "build": "npm run build:all",
    "build:all": "npm --prefix client run build",
    "start": "node server/server.js",
    "install:all": "npm install && npm --prefix client install && npm --prefix server install"
  },
  "devDependencies": {
    "kill-port": "^2.0.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.13.0",
    "mongoose": "^8.9.6",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0"
  }
}
