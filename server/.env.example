PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ramjibakery
JWT_SECRET=replace-with-a-secure-secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
ADMIN_EMAIL=admin@ramjibakery.in
ADMIN_PASSWORD=change-this-password
SUPERADMIN_EMAIL=superadmin@ramjibakery.in
SUPERADMIN_PASSWORD_HASH=
SUPERADMIN_PASSWORD=
OWNER_PHONE=0000000000
OWNER_EMAIL=your-email@example.com
SMTP_USER=your-email@example.com
SMTP_PASS=your-gmail-app-password
ENABLE_ORDER_EMAIL=false
ORDER_NOTIFICATION_WHATSAPP=910000000000
FRONTEND_URL=https://ram-ji-bakery23.vercel.app
NODE_ENV=production

# --- DEPLOYMENT GUIDE ---
# LOCAL (.env):
# Use the values above in your local .env file.
# 
# DEPLOY (Render & Vercel):
# Add SAME variables in dashboard Environment section.
# Make sure to never use "localhost" in production variables.
